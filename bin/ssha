#!/usr/bin/env bash
# IMPORTANT: pas de "set -e" ici non plus.
set -u
set -o pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

# shellcheck disable=SC1091
source "${ROOT_DIR}/lib/ssha_colors.sh"

# shellcheck disable=SC1091
source "${ROOT_DIR}/lib/ssha_core.sh"

ssha::main "$@"
